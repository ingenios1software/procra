{
  "name": "procra-functions",
  "private": true,
  "main": "dist/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "seed:demo": "npm run build && node dist/scripts/seed-demo.js",
    "seed:demo:reset": "npm run seed:demo -- --reset",
    "seed:clean": "npm run build && node dist/scripts/seed-clean.js"
  },
  "dependencies": {
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^5.7.3"
  }
}
