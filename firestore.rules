
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserDoc() {
      return signedIn() && exists(userPath());
    }

    function userDoc() {
      return get(userPath()).data;
    }

    function roleIs(role) {
      return hasUserDoc() && userDoc().role == role;
    }

    function admin() {
      return roleIs('admin');
    }

    function supervisor() {
      return roleIs('supervisor');
    }

    function capataz() {
      return roleIs('capataz');
    }

    function canOperateSite(siteId) {
      return hasUserDoc() && (
        admin() ||
        supervisor() ||
        (capataz() && ('siteIds' in userDoc()) && (siteId in userDoc().siteIds))
      );
    }

    match /users/{uid} {
      allow read: if signedIn() && (uid == request.auth.uid || admin());
      allow create, update, delete: if admin();
    }

    match /workers/{workerId} {
      allow read: if signedIn();
      allow create, update: if admin() || supervisor();
      allow delete: if admin();
    }

    match /sites/{siteId} {
      allow read: if signedIn();
      allow create, update: if admin() || supervisor();
      allow delete: if admin();
    }

    match /periods/{periodId} {
      allow read: if signedIn();
      allow create, update, delete: if admin();
    }

    match /attendances/{attendanceId} {
      allow read: if signedIn();

      allow create: if signedIn() &&
        (admin() || supervisor() || capataz()) &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status == 'draft' &&
        canOperateSite(request.resource.data.siteId);

      allow update: if (
        (admin() || supervisor()) &&
        canOperateSite(request.resource.data.siteId)
      ) || (
        capataz() &&
        resource.data.createdBy == request.auth.uid &&
        resource.data.status == 'draft' &&
        request.resource.data.status == 'draft' &&
        canOperateSite(request.resource.data.siteId)
      );

      allow delete: if admin();
    }

    match /adjustments/{adjustmentId} {
      allow read: if signedIn();
      allow create, update: if admin() || supervisor();
      allow delete: if admin();
    }

    match /settlements/{settlementId} {
      allow read: if signedIn();
      allow create, update, delete: if admin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
