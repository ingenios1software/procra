rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regla global predeterminada: denegar todo por seguridad.
    match /{document=**} {
      allow read, write: if false;
    }

    // Un usuario solo puede leer su propio perfil.
    // Un usuario solo puede crear o actualizar su propio perfil.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Permite la lectura y escritura para cualquier usuario autenticado en el resto de las colecciones.
    // Esto es permisivo para la etapa de desarrollo.
    // ¡RECUERDA RESTRINGIR ESTO ANTES DE IR A PRODUCCIÓN!
    match /parcelas/{parcelaId} {
      allow read, write: if request.auth != null;
    }
    match /cultivos/{cultivoId} {
      allow read, write: if request.auth != null;
    }
    match /zafras/{zafraId} {
      allow read, write: if request.auth != null;
    }
    match /eventos/{eventoId} {
      allow read, write: if request.auth != null;
    }
    match /roles/{roleId} {
      allow read, write: if request.auth != null;
    }
     match /insumos/{insumoId} {
      allow read, write: if request.auth != null;
    }
     match /MovimientosStock/{movimientoId} {
      allow read, write: if request.auth != null;
    }
    match /compras/{compraId} {
      allow read, write: if request.auth != null;
    }
    match /ventas/{ventaId} {
      allow read, write: if request.auth != null;
    }
    match /maquinaria/{maquinariaId} {
      allow read, write: if request.auth != null;
    }
    match /clientes/{clienteId} {
      allow read, write: if request.auth != null;
    }
    match /proveedores/{proveedorId} {
      allow read, write: if request.auth != null;
    }
    match /plagas/{plagaId} {
      allow read, write: if request.auth != null;
    }
    match /etapasCultivo/{etapaId} {
      allow read, write: if request.auth != null;
    }
    match /empleados/{empleadoId} {
      allow read, write: if request.auth != null;
    }
    match /asistencias/{asistenciaId} {
      allow read, write: if request.auth != null;
    }
    match /planDeCuentas/{cuentaId} {
      allow read, write: if request.auth != null;
    }
    match /centrosDeCosto/{centroId} {
      allow read, write: if request.auth != null;
    }
    match /asientosDiario/{asientoId} {
      allow read, write: if request.auth != null;
    }
    // Deprecated collection, but keep rule for safety during transition
    match /costos/{costoId} {
      allow read, write: if request.auth != null;
    }
  }
}
