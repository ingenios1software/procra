rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Regla general para todas las colecciones principales ---
    // Permite a cualquier usuario autenticado leer (listar/obtener) y escribir
    // en cualquiera de los documentos de las colecciones principales.
    // Esto es apropiado para un entorno de desarrollo.

    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    match /plots/{plotId} {
      allow read, write: if isAuthenticated();
    }

    match /crops/{cropId} {
      allow read, write: if isAuthenticated();
    }

    match /seasons/{seasonId} {
      allow read, write: if isAuthenticated();
    }

    match /events/{eventId} {
      allow read, write: if isAuthenticated();
    }
    
    // Reglas para subcolecciones (si las hubiera)
    match /plots/{plotId}/events/{eventId} {
        allow read, write: if isAuthenticated();
    }

    match /roles/{roleId} {
      allow read, write: if isAuthenticated();
    }
    
    match /insumos/{insumoId} {
      allow read, write: if isAuthenticated();
    }

    match /MovimientosStock/{movimientoId} {
      allow read, write: if isAuthenticated();
    }
    
    match /compras/{compraId} {
      allow read, write: if isAuthenticated();
    }
    
    match /ventas/{ventaId} {
      allow read, write: if isAuthenticated();
    }
    
    match /maquinaria/{maquinariaId} {
      allow read, write: if isAuthenticated();
    }

    match /clientes/{clienteId} {
      allow read, write: if isAuthenticated();
    }

    match /proveedores/{proveedorId} {
      allow read, write: if isAuthenticated();
    }

    match /plagas/{plagaId} {
      allow read, write: if isAuthenticated();
    }

    match /etapasCultivo/{etapaId} {
      allow read, write: if isAuthenticated();
    }

    match /empleados/{empleadoId} {
      allow read, write: if isAuthenticated();
    }
    
    match /asistencias/{asistenciaId} {
      allow read, write: if isAuthenticated();
    }

    match /planDeCuentas/{cuentaId} {
      allow read, write: if isAuthenticated();
    }

    match /centrosDeCosto/{centroId} {
      allow read, write: if isAuthenticated();
    }

    match /asientosDiario/{asientoId} {
      allow read, write: if isAuthenticated();
    }

    // --- Colecciones que estaban en reglas anteriores ---
    match /costos/{costoId} {
      allow read, write: if isAuthenticated();
    }

    match /zafras/{zafraId} {
      allow read, write: if isAuthenticated();
    }
    
    match /eventos/{eventoId} {
        allow read, write: if isAuthenticated();
    }
    
    match /parcelas/{parcelaId} {
      allow read, write: if isAuthenticated();
    }

    match /cultivos/{cultivoId} {
      allow read, write: if isAuthenticated();
    }
    
    match /usuarios/{usuarioId} {
      allow read, write: if isAuthenticated();
    }
  }
}
