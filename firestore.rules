
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function getUsuario() {
      // Devuelve los datos del documento del usuario autenticado.
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }
    
    function hasPerm(module) {
      // Verifica si el usuario tiene un permiso específico activado.
      // Asegurarse que el campo 'permisos' y el módulo existan para evitar errores.
      return 'permisos' in getUsuario() &&
             getUsuario().permisos != null &&
             module in getUsuario().permisos &&
             getUsuario().permisos[module] == true;
    }
    
    function isAuthenticated() {
      // Verifica si hay un usuario autenticado en la solicitud.
      return request.auth != null;
    }

    function isAdmin() {
      // Verifica si el rol del usuario es 'admin'.
      return getUsuario().rol == 'admin';
    }

    // -- Reglas de Acceso a Colecciones --

    // Colección de Usuarios:
    // Lectura: Cualquier usuario autenticado puede leer perfiles (ajustar si es necesario).
    // Escritura: Solo los administradores pueden modificar perfiles de usuario.
    match /usuarios/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Módulos con permisos específicos
    match /comprasNormal/{document=**} {
      allow read, write: if hasPerm('compras');
    }
    
    match /MovimientosStock/{document=**} {
      allow read, write: if hasPerm('stock');
    }

    match /eventos/{document=**} {
      allow read, write: if hasPerm('eventos');
    }
    
    match /ventas/{document=**} {
      allow read, write: if hasPerm('ventas');
    }
    
    // Módulo de Monitoreo (si existiera como colección)
    match /monitoreos/{document=**} {
      allow read, write: if hasPerm('monitoreos');
    }

    // -- Resto de colecciones con regla general (para no romper la app) --
    // Se recomienda ajustar estas reglas a futuro para mayor seguridad.
    match /plots/{document=**} { allow read, write: if isAuthenticated(); }
    match /crops/{document=**} { allow read, write: if isAuthenticated(); }
    match /seasons/{document=**} { allow read, write: if isAuthenticated(); }
    match /roles/{document=**} { allow read, write: if isAuthenticated(); }
    match /planDeCuentas/{document=**} { allow read, write: if isAuthenticated(); }
    match /centrosDeCosto/{document=**} { allow read, write: if isAuthenticated(); }
    match /asientosDiario/{document=**} { allow read, write: if isAuthenticated(); }
    match /parcelas/{document=**} { allow read, write: if isAuthenticated(); }
    match /cultivos/{document=**} { allow read, write: if isAuthenticated(); }
    match /zafras/{document=**} { allow read, write: if isAuthenticated(); }
    match /maquinaria/{document=**} { allow read, write: if isAuthenticated(); }
    match /proveedores/{document=**} { allow read, write: if isAuthenticated(); }
    match /clientes/{document=**} { allow read, write: if isAuthenticated(); }
    match /etapasCultivo/{document=**} { allow read, write: if isAuthenticated(); }
    match /plagas/{document=**} { allow read, write: if isAuthenticated(); }
    match /asistencias/{document=**} { allow read, write: if isAuthenticated(); }
    match /empleados/{document=**} { allow read, write: if isAuthenticated(); }
    match /depositos/{document=**} { allow read, write: if isAuthenticated(); }
    match /insumos/{document=**} { allow read, write: if isAuthenticated(); }
    match /entidades/{document=**} { allow read, write: if isAuthenticated(); }
    match /cuentasCajaBanco/{document=**} { allow read, write: if isAuthenticated(); }
    match /cuentasContables/{document=**} { allow read, write: if isAuthenticated(); }
    match /monedas/{document=**} { allow read, write: if isAuthenticated(); }
    match /planesFinanciacion/{document=**} { allow read, write: if isAuthenticated(); }
    match /tiposDocumento/{document=**} { allow read, write: if isAuthenticated(); }
    match /formasPago/{document=**} { allow read, write: if isAuthenticated(); }
  }
}
