{
  "entities": {
    "Plot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Plot",
      "type": "object",
      "description": "Represents a plot of land for agricultural purposes.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Plot entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the plot."
        },
        "code": {
          "type": "string",
          "description": "Code or identifier for the plot."
        },
        "area": {
          "type": "number",
          "description": "Area of the plot in a specific unit (e.g., hectares, acres)."
        },
        "location": {
          "type": "string",
          "description": "Geographic location of the plot."
        },
        "status": {
          "type": "string",
          "description": "Current status of the plot (e.g., active, inactive, fallow)."
        }
      },
      "required": [
        "id",
        "name",
        "code",
        "area",
        "location",
        "status"
      ]
    },
    "Crop": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Crop",
      "type": "object",
      "description": "Represents a type of crop.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Crop entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the crop."
        },
        "description": {
          "type": "string",
          "description": "Description of the crop."
        }
      },
      "required": [
        "id",
        "name",
        "description"
      ]
    },
    "Season": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Season",
      "type": "object",
      "description": "Represents an agricultural season (zafra).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Season entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the season."
        },
        "startDate": {
          "type": "string",
          "description": "Start date of the season.",
          "format": "date-time"
        },
        "endDate": {
          "type": "string",
          "description": "End date of the season.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "Current status of the season (e.g., active, closed)."
        }
      },
      "required": [
        "id",
        "name",
        "startDate",
        "endDate",
        "status"
      ]
    },
    "Event": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Event",
      "type": "object",
      "description": "Represents an agricultural event that occurs on a plot during a season.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Event entity."
        },
        "plotId": {
          "type": "string",
          "description": "Reference to Plot. (Relationship: Plot 1:N Event)"
        },
        "cropId": {
          "type": "string",
          "description": "Reference to Crop. (Relationship: Crop 1:N Event)"
        },
        "seasonId": {
          "type": "string",
          "description": "Reference to Season. (Relationship: Season 1:N Event)"
        },
        "type": {
          "type": "string",
          "description": "Type of event (e.g., planting, harvesting, fertilization)."
        },
        "date": {
          "type": "string",
          "description": "Date of the event.",
          "format": "date-time"
        },
        "description": {
          "type": "string",
          "description": "Description of the event."
        },
        "inputs": {
          "type": "string",
          "description": "Inputs used during the event (e.g., fertilizer, pesticides)."
        },
        "quantity": {
          "type": "number",
          "description": "Quantity of inputs used."
        },
        "unit": {
          "type": "string",
          "description": "Unit of measurement for the quantity of inputs."
        },
        "result": {
          "type": "string",
          "description": "Result of the event."
        }
      },
      "required": [
        "id",
        "plotId",
        "cropId",
        "seasonId",
        "type",
        "date",
        "description",
        "inputs",
        "quantity",
        "unit",
        "result"
      ]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the user."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "roleId": {
          "type": "string",
          "description": "Reference to Role. (Relationship: Role 1:N User)"
        },
        "active": {
          "type": "boolean",
          "description": "Indicates whether the user account is active."
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "roleId",
        "active"
      ]
    },
    "Role": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Role",
      "type": "object",
      "description": "Represents a user role within the application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Role entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the role."
        },
        "description": {
          "type": "string",
          "description": "Description of the role and its permissions."
        }
      },
      "required": [
        "id",
        "name",
        "description"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/plots/{plotId}",
        "definition": {
          "entityName": "Plot",
          "schema": {
            "$ref": "#/backend/entities/Plot"
          },
          "description": "Stores plot information. Includes standard plot attributes (name, code, area, location, status).",
          "params": [
            {
              "name": "plotId",
              "description": "Unique identifier for the plot."
            }
          ]
        }
      },
      {
        "path": "/crops/{cropId}",
        "definition": {
          "entityName": "Crop",
          "schema": {
            "$ref": "#/backend/entities/Crop"
          },
          "description": "Stores crop information. Includes standard crop attributes (name, description).",
          "params": [
            {
              "name": "cropId",
              "description": "Unique identifier for the crop."
            }
          ]
        }
      },
      {
        "path": "/seasons/{seasonId}",
        "definition": {
          "entityName": "Season",
          "schema": {
            "$ref": "#/backend/entities/Season"
          },
          "description": "Stores season (zafra) information. Includes standard season attributes (name, startDate, endDate, status).",
          "params": [
            {
              "name": "seasonId",
              "description": "Unique identifier for the season."
            }
          ]
        }
      },
      {
        "path": "/plots/{plotId}/events/{eventId}",
        "definition": {
          "entityName": "Event",
          "schema": {
            "$ref": "#/backend/entities/Event"
          },
          "description": "Stores event information related to a specific plot. Includes denormalized plot data for authorization independence.",
          "params": [
            {
              "name": "plotId",
              "description": "Unique identifier for the plot."
            },
            {
              "name": "eventId",
              "description": "Unique identifier for the event."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user information. Includes user attributes (name, email, roleId, active).",
          "params": [
            {
              "name": "userId",
              "description": "Unique identifier for the user."
            }
          ]
        }
      },
      {
        "path": "/roles/{roleId}",
        "definition": {
          "entityName": "Role",
          "schema": {
            "$ref": "#/backend/entities/Role"
          },
          "description": "Stores role information. Includes role attributes (name, description).",
          "params": [
            {
              "name": "roleId",
              "description": "Unique identifier for the role."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore structure is designed to ensure Authorization Independence, support the required QAPs, and maintain data integrity. User roles are managed through a dedicated 'roles' collection, and user assignments to roles are stored within the user documents. Plots, Crops, Seasons, and Events are organized in collections. Events are nested within Plots to represent the 1:N relationship, with relevant plot data denormalized into the Event documents to achieve Authorization Independence, eliminating the need for `get()` calls in security rules and enabling atomic operations. This approach also supports QAPs by allowing secure list operations based on the denormalized plot data within the Event documents. The structure enforces a homogeneous security posture within each collection."
  }
}