rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    function hasCurrentUser() {
      return signedIn() && exists(currentUserPath());
    }

    function currentUser() {
      return get(currentUserPath()).data;
    }

    function isPlatformAdminEmail() {
      return signedIn() && (
        request.auth.token.email == "admin@crapro95.com" ||
        request.auth.token.email == "ricardo.ortellado@outlook.com"
      );
    }

    function isPlatformAdmin() {
      return hasCurrentUser() && currentUser().esSuperAdmin == true || isPlatformAdminEmail();
    }

    function isSameEmpresa(empresaId) {
      return hasCurrentUser() && currentUser().empresaId == empresaId;
    }

    function currentTenantRolePath(empresaId) {
      return /databases/$(database)/documents/empresas/$(empresaId)/roles/$(currentUser().rolId);
    }

    function hasCurrentTenantRole(empresaId) {
      return isSameEmpresa(empresaId) &&
        currentUser().rolId != null &&
        exists(currentTenantRolePath(empresaId));
    }

    function currentTenantRole(empresaId) {
      return get(currentTenantRolePath(empresaId)).data;
    }

    function canReadEmpresa(empresaId) {
      return isPlatformAdmin() || (isSameEmpresa(empresaId) && currentUser().activo == true);
    }

    function canManageEmpresa(empresaId) {
      return isPlatformAdmin() || (
        isSameEmpresa(empresaId) &&
        currentUser().activo == true &&
        (
          currentUser().rolNombre == "admin" ||
          currentUser().rolId == "admin" ||
          (hasCurrentTenantRole(empresaId) && currentTenantRole(empresaId).permisos.administracion == true)
        )
      );
    }

    function isLegacyTenantWriteRole() {
      return hasCurrentUser() && (
        currentUser().rolId == "operador" ||
        currentUser().rolNombre == "operador" ||
        currentUser().rolId == "tecnico" ||
        currentUser().rolNombre == "tecnico" ||
        currentUser().rolId == "tecnicoCampo" ||
        currentUser().rolNombre == "tecnicoCampo" ||
        currentUser().rolId == "supervisor" ||
        currentUser().rolNombre == "supervisor" ||
        currentUser().rolId == "capataz" ||
        currentUser().rolNombre == "capataz"
      );
    }

    function isLegacyTenantReadOnlyRole() {
      return hasCurrentUser() && (
        currentUser().rolId == "consulta" ||
        currentUser().rolNombre == "consulta" ||
        currentUser().rolId == "gerente" ||
        currentUser().rolNombre == "gerente" ||
        currentUser().rolId == "auditor" ||
        currentUser().rolNombre == "auditor"
      );
    }

    function hasTenantWriteAccess(empresaId) {
      return canManageEmpresa(empresaId) || (
        isSameEmpresa(empresaId) &&
        currentUser().activo == true &&
        !isLegacyTenantReadOnlyRole() &&
        (
          (hasCurrentTenantRole(empresaId) && currentTenantRole(empresaId).soloLectura != true) ||
          isLegacyTenantWriteRole()
        )
      );
    }

    match /usuarios/{uid} {
      allow get: if signedIn() && (
        uid == request.auth.uid ||
        isPlatformAdmin() ||
        (hasCurrentUser() && canManageEmpresa(resource.data.empresaId))
      );
      allow list: if isPlatformAdmin() || (
        hasCurrentUser() &&
        currentUser().empresaId != null &&
        canManageEmpresa(currentUser().empresaId)
      );
      allow create: if isPlatformAdmin();
      allow update: if isPlatformAdmin() || (
        hasCurrentUser() &&
        canManageEmpresa(resource.data.empresaId) &&
        request.resource.data.empresaId == resource.data.empresaId
      );
      allow delete: if isPlatformAdmin();
    }

    match /roles/{roleId} {
      allow read: if signedIn();
      allow write: if isPlatformAdmin();
    }

    match /empresas/{empresaId} {
      allow read: if canReadEmpresa(empresaId);
      allow create: if isPlatformAdmin();
      allow update: if canManageEmpresa(empresaId);
      allow delete: if isPlatformAdmin();

      match /roles/{docId} {
        allow read: if canReadEmpresa(empresaId);
        allow create, update, delete: if canManageEmpresa(empresaId);
      }

      match /{collectionId}/{docId} {
        allow read: if canReadEmpresa(empresaId);
        allow create, update, delete: if collectionId != "roles" && hasTenantWriteAccess(empresaId);
      }
    }

    match /{document=**} {
      allow read, write: if isPlatformAdmin();
    }
  }
}
